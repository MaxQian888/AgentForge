# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
.windsurfrules
.ace-tool/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
vendor/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Build / Production
# -----------------------------------------------------------------------------
/build/
dist/
/.next/
/out/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
/coverage/
junit.xml
*.test.js.snap
*.test.ts.snap
*.test.tsx.snap
/playwright-report/
/test-results/

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env*
!.env.example
!.env.template

# -----------------------------------------------------------------------------
# Logs / Debug
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------
# Compiled binaries
*.exe
*.dll
*.so
*.dylib
# Local env override
src-go/.env
# Build cache
.gocache/
.tmp-go-cache/
tmp-go-cache/

# -----------------------------------------------------------------------------
# Tauri / Rust
# -----------------------------------------------------------------------------
src-tauri/target/
src-tauri/binaries/server*
src-tauri/binaries/bridge*
src-tauri/binaries/im-bridge*
!src-tauri/binaries/.gitkeep

# -----------------------------------------------------------------------------
# Next.js / Vercel
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
.playwright-mcp/

# -----------------------------------------------------------------------------
# Temporary / Cache
# -----------------------------------------------------------------------------
.cache/
.tmp/
tmp-runtime/
.eslintcache
.parcel-cache
.turbo

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Git worktrees
.worktrees/
.claude/worktrees/

# Local test fixtures / sandboxed agent repos
data/repos/
src-go/data/repos/

# Codex / AI tool artifacts
.codex/
.codex/dev-all-state.json
.codex/runtime-logs/
.superpowers/

# Python
__pycache__/
*.py[cod]

# Claude Code local state
.claude/scheduled_tasks.lock
.claude/settings.local.json
