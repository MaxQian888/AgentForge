PORT=7778
GO_WS_URL=ws://localhost:7777/ws/bridge

# Claude-backed runtime
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_AUTH_TOKEN=anthropic-auth-token
CLAUDE_CODE_RUNTIME_MODEL=claude-sonnet-4-5

# Text-generation provider credentials
OPENAI_API_KEY=sk-openai-xxx
GOOGLE_GENERATIVE_AI_API_KEY=google-ai-key

# Command-based coding runtimes. Each command must read one JSON request from stdin
# and emit newline-delimited JSON events on stdout.
CODEX_RUNTIME_COMMAND=codex
CODEX_RUNTIME_MODEL=gpt-5-codex
OPENCODE_RUNTIME_COMMAND=opencode
OPENCODE_RUNTIME_MODEL=opencode-default

MAX_CONCURRENT_AGENTS=10
LOG_LEVEL=info
