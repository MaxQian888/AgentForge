{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AgentForge",
  "version": "0.1.0",
  "identifier": "dev.agentforge.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:backend && pnpm build:bridge && pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentForge",
        "width": 1440,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/server",
      "binaries/bridge"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
