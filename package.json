{
  "name": "agentforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:tauri": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "test:tauri:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --lib --ignore-filename-regex \"lib[.]rs$\" --fail-under-lines 80 --fail-under-functions 80",
    "build:backend": "node scripts/build-backend.js",
    "build:backend:dev": "node scripts/build-backend.js --current-only",
    "build:plugin:wasm": "node scripts/build-go-wasm-plugin.js",
    "build:updater-manifest": "node scripts/build-updater-manifest.js",
    "plugin:build": "node scripts/build-go-wasm-plugin.js",
    "create-plugin": "node scripts/create-plugin.js",
    "plugin:debug": "node scripts/debug-go-wasm-plugin.js",
    "plugin:dev": "node scripts/run-plugin-dev-stack.js",
    "plugin:verify": "node scripts/verify-plugin-dev-workflow.js",
    "plugin:verify:builtins": "node scripts/verify-built-in-plugin-bundle.js",
    "build:bridge": "node scripts/build-bridge.js",
    "build:bridge:dev": "node scripts/build-bridge.js --current-only",
    "dev:all": "node scripts/dev-all.js",
    "dev:all:status": "node scripts/dev-all.js status",
    "dev:all:stop": "node scripts/dev-all.js stop",
    "dev:all:logs": "node scripts/dev-all.js logs",
    "tauri:dev": "pnpm build:backend:dev && pnpm build:bridge:dev && pnpm tauri dev",
    "tauri:build": "pnpm tauri build",
    "build:desktop": "pnpm build:backend && pnpm build:bridge && pnpm tauri build",
    "verify:updater-artifacts": "node scripts/validate-updater-artifacts.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec eslint --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@blocknote/core": "0.47.3",
    "@blocknote/react": "0.47.3",
    "@blocknote/shadcn": "0.47.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "katex": "0.16.42",
    "lucide-react": "^0.577.0",
    "mermaid": "11.13.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
