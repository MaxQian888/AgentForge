{
  "name": "agentforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:tauri": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "test:tauri:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --lib --ignore-filename-regex \"lib[.]rs$\" --fail-under-lines 80 --fail-under-functions 80",
    "build:backend": "node scripts/build/build-backend.js",
    "build:backend:dev": "node scripts/build/build-backend.js --current-only",
    "build:im-bridge": "node scripts/build/build-im-bridge.js",
    "build:im-bridge:dev": "node scripts/build/build-im-bridge.js --current-only",
    "build:plugin:wasm": "node scripts/plugin/build-go-wasm-plugin.js",
    "build:updater-manifest": "node scripts/release/build-updater-manifest.js",
    "plugin:build": "node scripts/plugin/build-go-wasm-plugin.js",
    "create-plugin": "node scripts/plugin/create-plugin.js",
    "plugin:debug": "node scripts/plugin/debug-go-wasm-plugin.js",
    "plugin:dev": "node scripts/plugin/run-plugin-dev-stack.js",
    "plugin:verify": "node scripts/plugin/verify-plugin-dev-workflow.js",
    "plugin:verify:builtins": "node scripts/plugin/verify-built-in-plugin-bundle.js",
    "skill:sync:mirrors": "node scripts/skills/sync-internal-skill-mirrors.js",
    "skill:verify:internal": "node scripts/skills/verify-internal-skills.js",
    "skill:verify:builtins": "node scripts/skills/verify-built-in-skill-bundle.js",
    "build:bridge": "node scripts/build/build-bridge.js",
    "build:bridge:dev": "node scripts/build/build-bridge.js --current-only",
    "desktop:dev:prepare": "pnpm build:backend:dev && pnpm build:bridge:dev && pnpm build:im-bridge:dev",
    "desktop:standalone:check": "pnpm desktop:dev:prepare && cargo run --manifest-path src-tauri/Cargo.toml --bin agentforge-desktop-cli -- check",
    "desktop:standalone:dev": "pnpm desktop:dev:prepare && cargo run --manifest-path src-tauri/Cargo.toml --bin agentforge-desktop-cli -- run",
    "desktop:build:prepare": "pnpm build:backend && pnpm build:bridge && pnpm build:im-bridge && pnpm build",
    "dev:all": "node scripts/dev/dev-all.js all",
    "dev:all:status": "node scripts/dev/dev-all.js all status",
    "dev:all:stop": "node scripts/dev/dev-all.js all stop",
    "dev:all:logs": "node scripts/dev/dev-all.js all logs",
    "dev:all:watch": "node scripts/dev/dev-all.js all watch",
    "dev:all:verify": "node scripts/dev/dev-all.js all verify",
    "dev:all:restart": "node scripts/dev/dev-all.js all restart",
    "dev:backend": "node scripts/dev/dev-all.js backend",
    "dev:backend:status": "node scripts/dev/dev-all.js backend status",
    "dev:backend:stop": "node scripts/dev/dev-all.js backend stop",
    "dev:backend:logs": "node scripts/dev/dev-all.js backend logs",
    "dev:backend:verify": "node scripts/dev/dev-all.js backend verify",
    "dev:backend:watch": "node scripts/dev/dev-all.js backend watch",
    "dev:backend:restart": "node scripts/dev/dev-all.js backend restart",
    "tauri:dev": "pnpm tauri dev",
    "tauri:build": "pnpm tauri build",
    "build:desktop": "pnpm tauri build",
    "verify:updater-artifacts": "node scripts/release/validate-updater-artifacts.js",
    "prepare": "husky",
    "i18n:audit": "node scripts/i18n/i18n-audit.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm exec eslint --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@blocknote/core": "0.47.3",
    "@blocknote/react": "0.47.3",
    "@blocknote/shadcn": "0.47.3",
    "@dnd-kit/core": "^6.3.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "~2.7.0",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "katex": "0.16.45",
    "lucide-react": "^1.8.0",
    "mermaid": "11.14.0",
    "next": "^16.2.3",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
