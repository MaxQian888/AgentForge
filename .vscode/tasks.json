{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ui:dev",
      "type": "shell",
      "isBackground": true,
      "command": "pnpm",
      "args": ["dev"],
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:|ready started server on)"
        }
      }
    },
    {
      "label": "ui:dev-if-needed",
      "type": "shell",
      "isBackground": true,
      // Default command won't be used due to per-OS overrides below
      "command": "pnpm",
      "args": ["dev"],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "if (Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue) { exit 0 } else { New-Item -ItemType File -Path \"${workspaceFolder}\\.vscode\\.ui-dev.lock\" -Force | Out-Null; pnpm dev }"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "lsof -ti :3000 >/dev/null 2>&1 && exit 0 || { mkdir -p \"${workspaceFolder}/.vscode\"; touch \"${workspaceFolder}/.vscode/.ui-dev.lock\"; pnpm dev; }"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "lsof -ti :3000 >/dev/null 2>&1 && exit 0 || { mkdir -p \"${workspaceFolder}/.vscode\"; touch \"${workspaceFolder}/.vscode/.ui-dev.lock\"; pnpm dev; }"
        ]
      },
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:|ready started server on)"
        }
      }
    },
    {
      "label": "ui:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"]
    },
    {
      "label": "ui:lint",
      "type": "shell",
      "command": "pnpm",
      "args": ["lint"],
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "ui:typecheck",
      "type": "shell",
      "command": "pnpm",
      "args": ["exec", "tsc", "--noEmit"],
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "ui:test",
      "type": "shell",
      "command": "pnpm",
      "args": ["test"],
      "group": "test"
    },
    {
      "label": "ui:test:coverage",
      "type": "shell",
      "command": "pnpm",
      "args": ["test:coverage"],
      "group": "test"
    },
    {
      "label": "bridge:dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["--dir", "src-bridge", "dev"]
    },
    {
      "label": "bridge:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["--dir", "src-bridge", "build"],
      "group": "build"
    },
    {
      "label": "bridge:typecheck",
      "type": "shell",
      "command": "pnpm",
      "args": ["--dir", "src-bridge", "typecheck"],
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "backend:dev",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/server"],
      "options": {
        "cwd": "${workspaceFolder}/src-go"
      }
    },
    {
      "label": "backend:build",
      "type": "shell",
      "command": "go",
      "args": ["build", "./cmd/server"],
      "options": {
        "cwd": "${workspaceFolder}/src-go"
      },
      "group": "build"
    },
    {
      "label": "backend:test",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/src-go"
      },
      "group": "test"
    },
    {
      "label": "backend:vet",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/src-go"
      }
    },
    {
      "label": "im-bridge:dev",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/bridge"],
      "options": {
        "cwd": "${workspaceFolder}/src-im-bridge"
      }
    },
    {
      "label": "im-bridge:build",
      "type": "shell",
      "command": "go",
      "args": ["build", "./cmd/bridge"],
      "options": {
        "cwd": "${workspaceFolder}/src-im-bridge"
      },
      "group": "build"
    },
    {
      "label": "im-bridge:test",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/src-im-bridge"
      },
      "group": "test"
    },
    {
      "label": "im-bridge:vet",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/src-im-bridge"
      }
    },
    {
      "label": "marketplace:dev",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/server"],
      "options": {
        "cwd": "${workspaceFolder}/src-marketplace"
      }
    },
    {
      "label": "marketplace:build",
      "type": "shell",
      "command": "go",
      "args": ["build", "./cmd/server"],
      "options": {
        "cwd": "${workspaceFolder}/src-marketplace"
      },
      "group": "build"
    },
    {
      "label": "marketplace:test",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/src-marketplace"
      },
      "group": "test"
    },
    {
      "label": "marketplace:vet",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "options": {
        "cwd": "${workspaceFolder}/src-marketplace"
      }
    },
    {
      "label": "desktop:dev:prepare",
      "type": "shell",
      "command": "pnpm",
      "args": ["desktop:dev:prepare"]
    },
    {
      "label": "desktop:dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["tauri:dev"]
    },
    {
      "label": "desktop:build:prepare",
      "type": "shell",
      "command": "pnpm",
      "args": ["desktop:build:prepare"]
    },
    {
      "label": "desktop:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["tauri:build"],
      "group": "build"
    },
    {
      "label": "desktop:test:tauri",
      "type": "shell",
      "command": "pnpm",
      "args": ["test:tauri"],
      "group": "test"
    },
    {
      "label": "desktop:test:tauri:coverage",
      "type": "shell",
      "command": "pnpm",
      "args": ["test:tauri:coverage"],
      "group": "test"
    },
    {
      "label": "desktop:debug:prepare",
      "dependsOrder": "sequence",
      "dependsOn": ["desktop:dev:prepare", "ui:dev-if-needed"]
    },
    {
      "label": "ui:stop",
      "type": "shell",
      "command": "",
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "if (Test-Path \"${workspaceFolder}\\.vscode\\.ui-dev.lock\") { $pid = (Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1 -ExpandProperty OwningProcess); if ($pid) { Stop-Process -Id $pid -Force }; Remove-Item -Force \"${workspaceFolder}\\.vscode\\.ui-dev.lock\" }"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "if [ -f \"${workspaceFolder}/.vscode/.ui-dev.lock\" ]; then lsof -ti :3000 | xargs -r kill -9 2>/dev/null; rm -f \"${workspaceFolder}/.vscode/.ui-dev.lock\"; fi"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "if [ -f \"${workspaceFolder}/.vscode/.ui-dev.lock\" ]; then lsof -ti :3000 | xargs kill -9 2>/dev/null || true; rm -f \"${workspaceFolder}/.vscode/.ui-dev.lock\"; fi"
        ]
      },
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "never",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "fullstack:dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:all"]
    },
    {
      "label": "fullstack:status",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:all:status"]
    },
    {
      "label": "fullstack:stop",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:all:stop"]
    },
    {
      "label": "fullstack:logs",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev:all:logs"]
    },
    {
      "label": "quality:check",
      "dependsOrder": "sequence",
      "dependsOn": [
        "ui:lint",
        "ui:typecheck",
        "ui:test",
        "bridge:typecheck",
        "backend:test",
        "backend:vet",
        "im-bridge:test",
        "im-bridge:vet",
        "marketplace:test",
        "marketplace:vet"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
